{
	"name": "we-love-pdf",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^24.13.2",
		"@types/node-forge": "^1.3.14",
		"@vitest/browser-playwright": "^4.1.9",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.2.0"
	},
	"dependencies": {
		"@embedpdf/engines": "^2.14.4",
		"@embedpdf/models": "^2.14.4",
		"@embedpdf/pdfium": "^2.14.4",
		"@embedpdf/svelte-pdf-viewer": "^2.14.4",
		"@lucide/svelte": "^1.23.0",
		"@signpdf/placeholder-plain": "^3.3.0",
		"@signpdf/signer-p12": "^3.3.0",
		"@signpdf/signpdf": "^3.3.0",
		"bits-ui": "^2.18.1",
		"buffer": "^6.0.3",
		"clsx": "^2.1.1",
		"docx": "^9.7.1",
		"fflate": "^0.8.3",
		"mammoth": "^1.12.0",
		"node-forge": "^1.4.0",
		"pdf-lib": "^1.17.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"xlsx": "^0.18.5"
	}
